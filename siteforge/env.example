# Copy to .env and fill in values. Do not commit .env.

# Required for production
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Optional
DEBUG=False
# SQLite: omit DATABASE_PATH to use db.sqlite3 in project root, or set a path:
# DATABASE_PATH=/home/siteforge/app/siteforge/db.sqlite3
STATIC_ROOT=/path/to/your/staticfiles
MEDIA_ROOT=/path/to/your/media

# S3 (optional – if set, uploads go to S3)
# AWS_STORAGE_BUCKET_NAME=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_REGION_NAME=us-east-1
