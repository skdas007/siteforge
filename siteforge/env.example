# Copy to .env and fill in values. Do not commit .env.

# Required for production
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=bobdyinternational.com,www.bobdyinternational.com,amberonlinestore.com,www.amberonlinestore.com

# Optional
DEBUG=False
# SQLite: omit DATABASE_PATH to use db.sqlite3 in project root, or set a path:
# DATABASE_PATH=/home/siteforge/app/siteforge/db.sqlite3
STATIC_ROOT=/path/to/your/staticfiles
MEDIA_ROOT=/path/to/your/media

# S3: when set, static and media are stored in the bucket (recommended for production)
# AWS_STORAGE_BUCKET_NAME=your-bucket
# AWS_ACCESS_KEY_ID=...   (or AWS_ACCESS_KEY=...)
# AWS_SECRET_ACCESS_KEY=...
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=   # optional; if unset, URLs use regional endpoint (bucket.s3.REGION.amazonaws.com)
# AWS_S3_QUERYSTRING_AUTH=false   # plain URLs for images; bucket must allow public GetObject
# Set to true to serve CSS/JS from server (Nginx) instead of S3; run collectstatic and enable /static/ in Nginx
# SERVE_STATIC_FROM_SERVER=true

# Image uploads: auto-resize + WebP (raster only; SVG/favicon/animated GIF unchanged)
# IMAGE_AUTO_COMPRESS=true
# IMAGE_UPLOAD_MAX_SIDE=2400
# IMAGE_UPLOAD_LOGO_MAX_SIDE=1200
# IMAGE_UPLOAD_BANNER_MAX_SIDE=2560
# IMAGE_UPLOAD_SEO_MAX_SIDE=1600
# IMAGE_UPLOAD_THEME_PREVIEW_MAX_SIDE=1600
# IMAGE_WEBP_QUALITY=82
# IMAGE_TRY_AVIF=false
# IMAGE_AVIF_QUALITY=70


