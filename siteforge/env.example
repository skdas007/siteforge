# SiteForge environment variables. Copy to .env and set values (do not commit .env).

# Required in production
SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database (optional: omit for SQLite with default db.sqlite3)
# DATABASE_PATH=db.sqlite3
# For PostgreSQL later:
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Optional for development
# REDIS_URL=redis://localhost:6379/0

# AWS S3 for media storage (set AWS_STORAGE_BUCKET_NAME to enable)
# AWS_ACCESS_KEY_ID=          (or AWS_ACCESS_KEY)
# AWS_SECRET_ACCESS_KEY=      (or AWS_SECREAT_KEY - typo supported)
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=       (optional, e.g. CDN or custom domain)

# Email (for contact form notifications)
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Optional
# STATIC_ROOT=/var/www/siteforge/static
# MEDIA_ROOT=/var/www/siteforge/media
# SENTRY_DSN=
